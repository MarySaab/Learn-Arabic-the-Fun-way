# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your OWN values. Never commit ".env".
# ---------------------------------------------------------------------------

# Neon PostgreSQL. Get these from your Neon dashboard AFTER you reset the
# password (the old one you pasted earlier should be rotated).
# "DATABASE_URL" = the pooled connection string.
# "DIRECT_URL"   = the direct (non-pooled) connection string, used by Prisma
#                  migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# API Ninjas key — register free at https://api-ninjas.com and paste it here.
# This stays on the server; it is NOT exposed to the browser.
API_NINJAS_KEY="your_api_ninjas_key_here"
